# GitHub Task Agent - Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and should NEVER be committed.

# REQUIRED - Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# REQUIRED - GitHub Personal Access Token
# Scopes needed: repo (read/write), pull_requests (read/write)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-pat-here

# REQUIRED - Target repository (owner/repo format)
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=your-repo-name

# OPTIONAL - Issue label to pick up (default: agent-task)
# ISSUE_LABEL=agent-task

# OPTIONAL - Claude model (default: claude-opus-4-5)
# CLAUDE_MODEL=claude-sonnet-4-5

# OPTIONAL - Branch prefix for agent PRs (default: agent-fix)
# BRANCH_PREFIX=agent-fix

# OPTIONAL - Local workspace directory for cloned repos (default: ./workspace)
# WORKSPACE_DIR=./workspace
